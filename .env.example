# Environment Variables Example

# Local Environment (.env.local)
PORT=3000

# Supabase (PostgreSQL)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Authentication
ACCESS_TOKEN_SECRET="your-random-long-secret-string"
ACCESS_TOKEN_EXPIRY="1d"

# Redis Configuration (Local)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_URL=""

# BullMQ
BULLMQ_QUEUE_NAME="myQueue"


# ----------------------------------------------------
# Production Environment (.env.prod)
# ----------------------------------------------------
# PORT=3000
# 
# # Supabase (PostgreSQL)
# SUPABASE_URL="https://your-prod-project-ref.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-prod-supabase-service-role-key"
# 
# # Authentication (Use a very strong secret in production)
# ACCESS_TOKEN_SECRET="a-very-long-and-secure-random-string"
# ACCESS_TOKEN_EXPIRY="1d"
# 
# # Redis Configuration (Managed Redis e.g., Upstash, Render, Railway)
# REDIS_HOST="redis-prod-host.upstash.io"
# REDIS_PORT="6379"
# REDIS_PASSWORD="your-prod-redis-password"
# REDIS_URL="redis://default:password@host:port" # Sometimes you only need the REDIS_URL depending on the hosting provider
# 
# # BullMQ
# BULLMQ_QUEUE_NAME="prodQueue"
